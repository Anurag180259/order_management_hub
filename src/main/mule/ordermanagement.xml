    <flow name="post:\addCust:application\json:ordermanagement-config" doc:id="2403b034-3e02-4547-968a-6d3c42c73a09">
        <set-variable value="#[payload]" doc:name="OriginalPayload" doc:id="bc3d8795-cddc-47e0-b716-9cb5df48e157" variableName="originalPayload" />
        <set-variable value="#[&quot;C-&quot;++ uuid()[0 to 5]]" doc:name="SetCustId" doc:id="1c284721-1780-43df-bdf1-9ffcec1c02e2" variableName="custId" />
        <db:insert doc:name="Add Customer" doc:id="5d075c57-28d7-4f50-b1f6-eb414aa64c9a" config-ref="Database_Config">
            <reconnect count="5" />
            <db:sql><![CDATA[insert into cust_data(cust_id, cust_name, email, phone, city)
values(:id, :name, :email, :phone, :city);]]></db:sql>
            <db:input-parameters><![CDATA[#[{
	id:vars.custId,
	name:payload.custName,
	email:payload.email,
	phone:payload.phone,
	city:payload.city
}]]]></db:input-parameters>
        </db:insert>
        <set-variable value="#[201]" doc:name="httpStatusCode" doc:id="cf78b554-e893-4e5d-a825-3e722d4c55ec" variableName="httpStatus" />
        <ee:transform doc:name="Transform Message">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  message: "Thanks for registering into orderManagement",
  Cust_id:  vars.custId ++ " is your customer id"
} as Object {encoding: "UTF-8", mediaType: "application/json"}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <error-handler>
            <on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="42b38c5f-11b1-4ba2-b408-dc6e5ed07a16" type="DB:QUERY_EXECUTION">
                <set-variable value="#[409]" doc:name="httpStatusCode" doc:id="296b3641-6ca0-49cf-9ac2-f514b8a215b8" variableName="httpStatus" />
                <ee:transform doc:name="Duplicate Info Warning" doc:id="0e7860cb-b74e-498f-8f2b-7a0dcd9d35d1">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json

---
{
	Error:"Duplicate item found",
	Message:(if((error.description default "") contains (vars.originalPayload.email default "")) "Email is already registered. Use alternate Email" 
			else if((error.description default "") contains (vars.originalPayload.phone default "")) "PhoneNumber is already registered. Use alternate Number"
			else "Registration error")
			
}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </on-error-propagate>
        </error-handler>
    </flow>
    <sub-flow name="individualItemProcessing" doc:id="6cbfcd72-11d0-4a00-8199-2f19130bb350">
        <foreach doc:name="TotalPriceCalculation/stockUpdate" doc:id="9cd40c7d-cbb7-4d75-8e7e-4cf19cf90416" collection="#[payload.listOfItems]">
            <set-variable value="#[payload]" doc:name="item" doc:id="4c3b79e4-7014-46d3-bc4c-82d2e70d2c40" variableName="item" />
            <db:select doc:name="getProductDetails" doc:id="010d249b-4a15-41ac-a449-7a1e4fb3b484" config-ref="Database_Config">
                <db:sql><![CDATA[select * from inventory where product_id=:productId;]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	productId:payload.productId
}]]]></db:input-parameters>
            </db:select>
            <choice doc:name="checkAvailability" doc:id="577f688c-058d-48d2-b749-35793827ba5e">
                <when expression="#[vars.item.quantity&gt;payload[0].quantity]">
                    <set-variable value="#[payload[0].product_name]" doc:name="exceededProduct" doc:id="a02d42c5-cc9d-46b2-b4cc-9d96375ee558" variableName="exceededProduct" />
                    <raise-error doc:name="APP:QUANTITY_EXCEEDED" doc:id="e3bb503a-556c-4651-a18a-bb4dbd870a3e" type="APP:QUANTITY_EXCEEDED" />
                </when>
            </choice>
            <ee:transform doc:name="javaToJson" doc:id="3f1d609c-c736-44ba-bfe8-19d62cb41f0e">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
                </ee:message>
            </ee:transform>
            <set-variable value="#[vars.totalOrderPrice + ((payload)[0].price as Number)*vars.item.quantity]" doc:name="totalOrderPriceUpdate" doc:id="f071f942-d6ee-42aa-9998-90e5f428b26a" variableName="totalOrderPrice" />
            <db:update doc:name="updateQuantity" doc:id="17d09e62-5e9d-4fbc-b365-06604bf1a4b7" config-ref="Database_Config">
                <db:sql><![CDATA[update inventory
set quantity = quantity - :quan
where product_id = :productId]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	quan:vars.item.quantity,
	productId:vars.item.productId
}]]]></db:input-parameters>
            </db:update>
        </foreach>
    </sub-flow>
    <flow name="post:\order:application\json:ordermanagement-config" doc:id="1d12795b-cfbc-4ff4-ba9b-449b69b86f3e">
        <set-variable value="#[payload]" doc:name="original payload" doc:id="a1f13055-6b64-467f-8ac7-8e6af03b9f06" variableName="originalPayload" />
        <set-variable value="#[%dw 2.0&#xA;output application/json&#xA;---&#xA;0]" doc:name="totalOrderPrice" doc:id="540f2107-c77f-4516-97af-0108911998f3" variableName="totalOrderPrice" />
        <set-variable value="#[%dw 2.0&#xA;output application/json&#xA;---&#xA;&quot;O-&quot;++ uuid()[0 to 5]]" doc:name="orderId" doc:id="a64d4991-62b9-4a0e-a6ac-d82c6f48770b" variableName="orderId" />
        <set-variable value="#[%dw 2.0&#xA;output application/json&#xA;---&#xA;&quot; &quot;]" doc:name="exceeded product" doc:id="4abeb526-38d8-4793-ba77-8ec2bf4d4a44" variableName="exceededProduct" />
        <try doc:name="Try" doc:id="56f89d0d-9b67-47fc-8492-134de777fb14" transactionalAction="ALWAYS_BEGIN">
            <flow-ref doc:name="individualItemProcessing" doc:id="db9ccb7d-9280-4030-be13-30d743b3eb13" name="individualItemProcessing" />
            <db:select doc:name="getUserData" doc:id="66c99464-059f-440c-b01b-5c1ab0dd0641" config-ref="Database_Config">
                <db:sql><![CDATA[select * from cust_data where cust_id=:id;]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	id:vars.originalPayload.custId
}]]]></db:input-parameters>
            </db:select>
            <set-variable value="#[%dw 2.0&#xA;output application/json&#xA;---&#xA;if(lower(payload.city[0])==&quot;nagpur&quot;) |P4D| else if(lower(payload.city[0])==&quot;ahemdabad&quot;) |P6D| else |P110D|]" doc:name="deliveryTime" doc:id="c0fdcbe0-db58-444d-a657-a260cccc1560" variableName="deliveryTime" />
            <db:insert doc:name="Place order" doc:id="b7d34e1b-cc39-4226-91be-09b2e6fffdd5" config-ref="Database_Config">
                <db:sql><![CDATA[insert into order_table (order_id, cust_id, order_date, total_order_price, exp_del_date, delivery_status)
values(:id, :custId, curdate(), :totalOrderPrice, :expDelDate, "in transit");]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	id:vars.orderId,
	custId:vars.originalPayload.custId,
	totalOrderPrice:vars.totalOrderPrice,
	expDelDate:(now() as Date) + ((vars.deliveryTime) as Period)
}]]]></db:input-parameters>
            </db:insert>
            <foreach doc:name="orderItemsInsert" doc:id="49853f30-4eee-430e-99cd-0e8ca68d0f87" collection="#[vars.originalPayload.listOfItems]">
                <set-variable value="#[payload]" doc:name="product" doc:id="5101cfbf-3d27-412f-8b2a-e1238700b56a" variableName="product" />
                <db:select doc:name="getProductDetails" doc:id="1b26b8e4-35e7-4645-8737-63b2c2b03c5c" config-ref="Database_Config">
                    <db:sql><![CDATA[select * from inventory where product_id=:productId;]]></db:sql>
                    <db:input-parameters><![CDATA[#[{
	productId:payload.productId
}]]]></db:input-parameters>
                </db:select>
                <db:insert doc:name="orderItemsInsert" doc:id="3755a332-178d-4093-9b79-0f1066ac6c66" config-ref="Database_Config">
                    <db:sql><![CDATA[insert into order_items(order_id, product_id, quantity, order_price)
values(:orderId, :productId, :quantity, :orderPrice);]]></db:sql>
                    <db:input-parameters><![CDATA[#[{
	orderId:vars.orderId,
	productId:vars.product.productId,
	quantity:vars.product.quantity,
	orderPrice:payload[0].price
}]]]></db:input-parameters>
                </db:insert>
            </foreach>
            <error-handler>
                <on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="39c759bf-8b13-4057-a3c6-7bb5ed4777d8" type="APP:QUANTITY_EXCEEDED">
                    <set-variable value="#[422]" doc:name="httpStatusCode" doc:id="a4a15992-0c7e-4e4c-a9d9-c3936ebfa2c6" variableName="httpStatus" />
                    <ee:transform doc:name="quantity exceeded" doc:id="222ac260-d040-4304-a7f8-c83976724029">
                        <ee:message>
                            <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	"status":"error",
	"message":"Required quantity for " ++ vars.exceededProduct ++ " is not available"
}]]></ee:set-payload>
                        </ee:message>
                    </ee:transform>
                </on-error-propagate>
                <on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="d0a58ee3-fe68-49f6-9688-d09a65d1535d" type="ANY">
                    <ee:transform doc:name="reverted" doc:id="01d52cf6-ee16-4319-bc86-8f54b7989b38">
                        <ee:message>
                            <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	error:"Unexpected error occured",
	message:"Transaction reverted"
}]]></ee:set-payload>
                        </ee:message>
                    </ee:transform>
                </on-error-propagate>
            </error-handler>
        </try>
        <db:select doc:name="customerDetails" doc:id="6fec633f-0edf-4d2d-b9f8-692d9b5b2370" config-ref="Database_Config">
            <db:sql><![CDATA[select * from cust_data where cust_id=:custId;]]></db:sql>
            <db:input-parameters><![CDATA[#[{
	custId:vars.originalPayload.custId
}]]]></db:input-parameters>
        </db:select>
        <email:send doc:name="orderConfirmation" doc:id="f683f07f-4afd-4e76-b11e-bb7b01fac668" toAddresses="#[payload.email]" config-ref="Email_SMTP" fromAddress="anuragninawe1802@gmail.com" subject="Order confirmation">
            <reconnect count="10" />
            <email:body contentType="text/plain" contentTransferEncoding="8BIT">
                <email:content><![CDATA[#["Your order " ++ (vars.orderId default "") ++" has been successfully placed"]]]></email:content>
            </email:body>
        </email:send>
        <set-variable value="#[201]" doc:name="httpStatusCode" doc:id="6c896b22-8a73-4a0e-a487-f7e6976f2d97" variableName="httpStatus" />
        <ee:transform doc:name="Transform Message">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  message: "Your order has been successfully placed",
  order_id:vars.orderId
} as Object {encoding: "UTF-8", mediaType: "application/json"}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
    </flow>
