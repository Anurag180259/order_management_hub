		<set-variable value="#[output application/json&#10;---&#10;attributes.queryParams.orderId]" doc:name="orderId" doc:id="fc556223-682a-47c4-8e7e-84cc792083f1" variableName="orderId" />
        <db:select doc:name="ordersList" doc:id="f3f698cd-19b6-4eb3-a7b5-95bf23ce0b5b" config-ref="Database_Config">
            <db:sql><![CDATA[select * from order_table where cust_id=:custId;]]></db:sql>
