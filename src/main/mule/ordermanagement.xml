<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:apikit="http://www.mulesoft.org/schema/mule/mule-apikit" xmlns:db="http://www.mulesoft.org/schema/mule/db" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation" xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core" xmlns:email="http://www.mulesoft.org/schema/mule/email" xmlns:http="http://www.mulesoft.org/schema/mule/http" xmlns:tracking="http://www.mulesoft.org/schema/mule/ee/tracking" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd http://www.mulesoft.org/schema/mule/mule-apikit http://www.mulesoft.org/schema/mule/mule-apikit/current/mule-apikit.xsd http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd  http://www.mulesoft.org/schema/mule/db http://www.mulesoft.org/schema/mule/db/current/mule-db.xsd http://www.mulesoft.org/schema/mule/ee/tracking http://www.mulesoft.org/schema/mule/ee/tracking/current/mule-tracking-ee.xsd http://www.mulesoft.org/schema/mule/email http://www.mulesoft.org/schema/mule/email/current/mule-email.xsd">
    <http:listener-config name="ordermanagement-httpListenerConfig">
        <http:listener-connection host="0.0.0.0" port="8081" />
    </http:listener-config>
    <apikit:config name="ordermanagement-config" api="resource::297e1185-2a7e-4734-9d69-effb0bb9fbe9:ordermanagement:1.0.8:raml:zip:ordermanagement.raml" outboundHeadersMapName="outboundHeaders" httpStatusVarName="httpStatus" />
    <configuration-properties doc:name="Configuration properties" doc:id="6d352598-1ec4-4d14-9c54-c7c2e3301bca" file="configuration.properties" />
    <db:config name="Database_Config" doc:name="Database Config" doc:id="c120a618-ce31-4626-a64f-cbf440a70e64">
        <db:my-sql-connection host="${db.host}" port="${db.port}" user="${db.username}" password="${db.password}" database="order_management" />
    </db:config>
    <email:smtp-config name="Email_SMTP" doc:name="Email SMTP" doc:id="4b1fe9ef-3a46-4cb6-aba7-b85bf2e31911">
        <email:smtp-connection host="${smtp.host}" port="${smtp.port}" user="${smtp.username}" password="${smtp.password}" />
    </email:smtp-config>
    <flow name="ordermanagement-main">
        <http:listener config-ref="ordermanagement-httpListenerConfig" path="/api/*" outputMimeType="application/json">
            <http:response statusCode="#[vars.httpStatus default 200]">
                <http:headers><![CDATA[#[vars.outboundHeaders default {}]]]></http:headers>
            </http:response>
            <http:error-response statusCode="#[vars.httpStatus default 500]">
                <http:body><![CDATA[#[payload]]]></http:body>
                <http:headers><![CDATA[#[vars.outboundHeaders default {}]]]></http:headers>
            </http:error-response>
        </http:listener>
        <apikit:router config-ref="ordermanagement-config" />
        <error-handler>
            <on-error-propagate type="APIKIT:BAD_REQUEST">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Bad request"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:NOT_FOUND">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Resource not found"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">404</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:METHOD_NOT_ALLOWED">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Method not allowed"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">405</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:NOT_ACCEPTABLE">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Not acceptable"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">406</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:UNSUPPORTED_MEDIA_TYPE">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Unsupported media type"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">415</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
            <on-error-propagate type="APIKIT:NOT_IMPLEMENTED">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Not Implemented"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">501</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
        </error-handler>
    </flow>
    <flow name="ordermanagement-console">
        <http:listener config-ref="ordermanagement-httpListenerConfig" path="/console/*">
            <http:response statusCode="#[vars.httpStatus default 200]">
                <http:headers>#[vars.outboundHeaders default {}]</http:headers>
            </http:response>
            <http:error-response statusCode="#[vars.httpStatus default 500]">
                <http:body>#[payload]</http:body>
                <http:headers>#[vars.outboundHeaders default {}]</http:headers>
            </http:error-response>
        </http:listener>
        <apikit:console config-ref="ordermanagement-config" />
        <error-handler>
            <on-error-propagate type="APIKIT:NOT_FOUND">
                <ee:transform doc:name="Transform Message">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{message: "Resource not found"}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus">404</ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
        </error-handler>
    </flow>
    <flow name="post:\addCust:application\json:ordermanagement-config" doc:id="2403b034-3e02-4547-968a-6d3c42c73a09">
        <logger level="INFO" doc:name="input payload" doc:id="ab02d611-600a-424b-8bb6-478cca0858c9" message='#[{&#10;	flowName:"post:\addCust:application\json:ordermanagement-config",&#10;	inputPayload:payload&#10;}]'/>
		<set-variable value="#[payload]" doc:name="OriginalPayload" doc:id="bc3d8795-cddc-47e0-b716-9cb5df48e157" variableName="originalPayload" />
		<set-variable value='#[output application/json&#10;---&#10;"C-"++ uuid()[0 to 5] as String]' doc:name="SetCustId" doc:id="1c284721-1780-43df-bdf1-9ffcec1c02e2" variableName="custId"/>
        <logger level="INFO" doc:name="custId" doc:id="82c1f5f4-b0d0-4bcf-a62e-17b35f6a60cb" message="#[output application/json&#10;---&#10;{&#10;	generatedCustId:vars.custId as String&#10;}]"/>
		<logger level="INFO" doc:name="data sent in add customer query" doc:id="3eaeef16-e9bd-437e-b042-82846ce1af6c" message='#[output application/json&#10;---&#10;{&#10;	flowName:"addCustomer",&#10;	action:"inserting customer data into table",&#10;	id:vars.custId,&#10;	name:payload.custName,&#10;	email:payload.email,&#10;	phone:payload.phone,&#10;	city:payload.city&#10;}]'/>
		<db:insert doc:name="Add Customer" doc:id="5d075c57-28d7-4f50-b1f6-eb414aa64c9a" config-ref="Database_Config">
            <reconnect count="5" />
            <db:sql><![CDATA[insert into cust_data(cust_id, cust_name, email, phone, city)
values(:id, :name, :email, :phone, :city);]]></db:sql>
            <db:input-parameters><![CDATA[#[{
	id:vars.custId,
	name:payload.custName,
	email:payload.email,
	phone:payload.phone,
	city:payload.city
}]]]></db:input-parameters>
        </db:insert>
        <logger level="INFO" doc:name="cust data seccessfully added" doc:id="d75580a1-22ca-4319-bcf0-af803346ed28" message='#[{&#10;	data:"successfully inserting customer data",&#10;	response:payload&#10;}]'/>
		<set-variable value="#[201]" doc:name="httpStatusCode" doc:id="cf78b554-e893-4e5d-a825-3e722d4c55ec" variableName="httpStatus" />
        <ee:transform doc:name="Transform Message">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  message: "Thanks for registering into orderManagement",
  Cust_id:  vars.custId ++ " is your customer id"
} as Object {encoding: "UTF-8", mediaType: "application/json"}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <error-handler>
            <on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="42b38c5f-11b1-4ba2-b408-dc6e5ed07a16" type="DB:QUERY_EXECUTION">
                <set-variable value="#[409]" doc:name="httpStatusCode" doc:id="296b3641-6ca0-49cf-9ac2-f514b8a215b8" variableName="httpStatus" />
                <logger level="ERROR" doc:name="duplicate info warning" doc:id="2f7e1ea1-3f3e-48ea-9e20-06da272ae3c8" message='#[output application/json&#10;---&#10;{&#10;	error:"duplicate info",&#10;	message:"email/phoneNumber sent by user already exists in database"&#10;}]'/>
				<ee:transform doc:name="Duplicate Info Warning" doc:id="0e7860cb-b74e-498f-8f2b-7a0dcd9d35d1">
                    <ee:message>
                        <ee:set-payload><![CDATA[%dw 2.0
output application/json

---
{
	Error:"Duplicate item found",
	Message:(if((error.description default "") contains (vars.originalPayload.email default "")) "Email is already registered. Use alternate Email" 
			else if((error.description default "") contains (vars.originalPayload.phone default "")) "PhoneNumber is already registered. Use alternate Number"
			else "Registration error")
			
}]]></ee:set-payload>
                    </ee:message>
                </ee:transform>
            </on-error-propagate>
        </error-handler>
    </flow>
    <sub-flow name="individualItemProcessing" doc:id="6cbfcd72-11d0-4a00-8199-2f19130bb350">
        <logger level="INFO" doc:name="list of items" doc:id="3b22f71a-e188-4cf3-880e-0be578dbae5b" message='#[{&#10;	flowName:"individualItemProcessing",&#10;	listOfItems:payload&#10;}]'/>
		<foreach doc:name="TotalPriceCalculation/stockUpdate" doc:id="9cd40c7d-cbb7-4d75-8e7e-4cf19cf90416" collection="#[payload.listOfItems]">
            <set-variable value="#[output application/json&#10;---&#10;payload]" doc:name="item" doc:id="4c3b79e4-7014-46d3-bc4c-82d2e70d2c40" variableName="item" />
			<logger level="INFO" doc:name="data sent to get product details" doc:id="058c2d97-e40a-4741-9e94-629d9699a8a9" message='#[{&#10;	flowName:"individualItemProcessing",&#10;	action:"getting individual product details by product id",&#10;	productId:payload.productId&#10;}]'/>
			<db:select doc:name="getProductDetails" doc:id="010d249b-4a15-41ac-a449-7a1e4fb3b484" config-ref="Database_Config">
                <db:sql><![CDATA[select * from inventory where product_id=:productId;]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	productId:payload.productId
}]]]></db:input-parameters>
            </db:select>
            <logger level="INFO" doc:name="individual product details" doc:id="3a382237-b189-422a-b438-a910f27a12b9" message='#[{&#10;	info:"product data received",&#10;	data:payload&#10;}]'/>
			<choice doc:name="checkAvailability" doc:id="577f688c-058d-48d2-b749-35793827ba5e">
                <when expression="#[vars.item.quantity&gt;payload[0].quantity]">
                    <set-variable value="#[output application/json&#10;---&#10;payload[0].product_name]" doc:name="exceededProduct" doc:id="a02d42c5-cc9d-46b2-b4cc-9d96375ee558" variableName="exceededProduct" />
                    <raise-error doc:name="APP:QUANTITY_EXCEEDED" doc:id="e3bb503a-556c-4651-a18a-bb4dbd870a3e" type="APP:QUANTITY_EXCEEDED" />
                </when>
            </choice>
            <ee:transform doc:name="javaToJson" doc:id="3f1d609c-c736-44ba-bfe8-19d62cb41f0e">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
                </ee:message>
            </ee:transform>
            <set-variable value="#[output application/json&#10;---&#10;vars.totalOrderPrice + ((payload)[0].price as Number)*vars.item.quantity]" doc:name="totalOrderPriceUpdate" doc:id="f071f942-d6ee-42aa-9998-90e5f428b26a" variableName="totalOrderPrice" />
            <db:update doc:name="updateQuantity" doc:id="17d09e62-5e9d-4fbc-b365-06604bf1a4b7" config-ref="Database_Config">
                <db:sql><![CDATA[update inventory
set quantity = quantity - :quan
where product_id = :productId]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	quan:vars.item.quantity,
	productId:vars.item.productId
}]]]></db:input-parameters>
            </db:update>
			<logger level="INFO" doc:name="quantity updated" doc:id="36da27fd-dbfa-47c0-a203-a890380b1832" message='#[{&#10;	message:"quantity updated",&#10;	productId:vars.item.productId&#10;}]'/>
        </foreach>
		<logger level="INFO" doc:name="totalOrderPrice" doc:id="7ee497fd-5250-4122-bb0f-d699c6a2a2c8" message="#[{&#10;	totalOrderPrice:vars.totalOrderPrice&#10;}]"/>
    </sub-flow>
    <flow name="post:\order:application\json:ordermanagement-config" doc:id="1d12795b-cfbc-4ff4-ba9b-449b69b86f3e">
        <logger level="INFO" doc:name="input payload" doc:id="6f6fec7b-0fbd-489d-9c95-31a44f5333c6" message='#[{&#10;	flowName:"post:\order:application\json:ordermanagement-config",&#10;	inputPayload:payload&#10;}]'/>
		<set-variable value="#[output application/json&#10;---&#10;payload]" doc:name="original payload" doc:id="a1f13055-6b64-467f-8ac7-8e6af03b9f06" variableName="originalPayload" />
        <set-variable value="#[%dw 2.0&#xA;output application/json&#xA;---&#xA;0]" doc:name="totalOrderPrice" doc:id="540f2107-c77f-4516-97af-0108911998f3" variableName="totalOrderPrice" />
        <set-variable value='#[%dw 2.0&#10;output application/json&#10;---&#10;"O-"++ uuid()[0 to 5] as String]' doc:name="orderId" doc:id="a64d4991-62b9-4a0e-a6ac-d82c6f48770b" variableName="orderId" />
        <logger level="DEBUG" doc:name="generated orderId" doc:id="eebfc96d-dd78-4c05-a873-89b0e4a36e40" message="#[{&#10;	generatedOrderId:vars.orderId&#10;}]"/>
		<set-variable value="#[%dw 2.0&#xA;output application/json&#xA;---&#xA;&quot; &quot;]" doc:name="exceeded product" doc:id="4abeb526-38d8-4793-ba77-8ec2bf4d4a44" variableName="exceededProduct" />
        <try doc:name="Try" doc:id="56f89d0d-9b67-47fc-8492-134de777fb14" transactionalAction="ALWAYS_BEGIN">
            <flow-ref doc:name="individualItemProcessing" doc:id="db9ccb7d-9280-4030-be13-30d743b3eb13" name="individualItemProcessing" />
			<db:select doc:name="getUserData" doc:id="66c99464-059f-440c-b01b-5c1ab0dd0641" config-ref="Database_Config">
                <db:sql><![CDATA[select * from cust_data where cust_id=:id;]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	id:vars.originalPayload.custId
}]]]></db:input-parameters>
            </db:select>
            <logger level="INFO" doc:name="fetchCustData" doc:id="f2e5a908-c27c-4d99-bdb0-eb6da83c7c03" message='#[{&#10;	action:"customer data fetched",&#10;	data:payload&#10;}]'/>
			<set-variable value='#[%dw 2.0&#10;output application/json&#10;---&#10;if(lower(payload.city[0])=="nagpur") |P4D| else if(lower(payload.city[0])=="ahemdabad") |P6D|&#10;else if(lower(payload.city[0])=="pune") |P3D| else "notDeliverable"]' doc:name="deliveryTime" doc:id="c0fdcbe0-db58-444d-a657-a260cccc1560" variableName="deliveryTime" />
			<choice doc:name="Choice" doc:id="abf098a9-251d-49c1-88dc-243b7e527aa9" >
				<when expression='#[vars.deliveryTime == "notDeliverable"]'>
					<raise-error doc:name="Raise error" doc:id="6205ab2f-f64f-4573-9d2f-3f20d6958df4" type="APP:NOT_DELIVERABLE" />
				</when>
			</choice>
			<db:insert doc:name="Place order" doc:id="b7d34e1b-cc39-4226-91be-09b2e6fffdd5" config-ref="Database_Config">
                <db:sql><![CDATA[insert into order_table (order_id, cust_id, order_date, total_order_price, exp_del_date, delivery_status)
values(:id, :custId, curdate(), :totalOrderPrice, :expDelDate, "in transit");]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	id:vars.orderId,
	custId:vars.originalPayload.custId,
	totalOrderPrice:vars.totalOrderPrice,
	expDelDate:(now() as Date) + ((vars.deliveryTime) as Period)
}]]]></db:input-parameters>
            </db:insert>
            <logger level="INFO" doc:name="after place order" doc:id="173c5aa9-e03d-4fa8-9739-a471756c7bfa" message='#[{&#10;	message:"order placed successfully"&#10;}]'/>
			<foreach doc:name="orderItemsInsert" doc:id="49853f30-4eee-430e-99cd-0e8ca68d0f87" collection="#[vars.originalPayload.listOfItems]">
                <set-variable value="#[output application/json&#10;---&#10;payload]" doc:name="product" doc:id="5101cfbf-3d27-412f-8b2a-e1238700b56a" variableName="product" />
                <db:select doc:name="getProductDetails" doc:id="1b26b8e4-35e7-4645-8737-63b2c2b03c5c" config-ref="Database_Config">
                    <db:sql><![CDATA[select * from inventory where product_id=:productId;]]></db:sql>
                    <db:input-parameters><![CDATA[#[{
	productId:payload.productId
}]]]></db:input-parameters>
                </db:select>
                <ee:transform doc:name="Transform Message" doc:id="9b3f078a-f87b-477c-af25-df5c44846f68" >
					<ee:message >
						<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
payload]]></ee:set-payload>
					</ee:message>
				</ee:transform>
				<logger level="INFO" doc:name="after get product details" doc:id="6b9e1a09-458b-4477-99dd-531517c05a99" message='#[{&#10;	info:"fetched product details",&#10;	details:payload,&#10;	info:"inserting order item",&#10;	productId:vars.product.productId&#10;}]'/>
				<db:insert doc:name="orderItemsInsert" doc:id="3755a332-178d-4093-9b79-0f1066ac6c66" config-ref="Database_Config">
                    <db:sql><![CDATA[insert into order_items(order_id, product_id, quantity, order_price)
values(:orderId, :productId, :quantity, :orderPrice);]]></db:sql>
                    <db:input-parameters><![CDATA[#[{
	orderId:vars.orderId,
	productId:vars.product.productId,
	quantity:vars.product.quantity,
	orderPrice:payload[0].price
}]]]></db:input-parameters>
                </db:insert>
				<logger level="INFO" doc:name="after orderItemsInsert" doc:id="8dcc320a-1ffa-4bc3-bf61-85e72d356aeb" message='#[{&#10;	info:"item successfully inserted"&#10;}]'/>
            </foreach>
            <error-handler>
                <on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="39c759bf-8b13-4057-a3c6-7bb5ed4777d8" type="APP:QUANTITY_EXCEEDED">
                    <set-variable value="#[output application/json&#10;---&#10;422]" doc:name="httpStatusCode" doc:id="a4a15992-0c7e-4e4c-a9d9-c3936ebfa2c6" variableName="httpStatus" />
                    <logger level="ERROR" doc:name="quantityExceeded" doc:id="259bbc6d-a772-4ed3-8b9d-d6a7ee688f0e" message='#[output application/json&#10;---&#10;{&#10;	error:"lowStock"&#10;}]'/>
					<ee:transform doc:name="quantity exceeded" doc:id="222ac260-d040-4304-a7f8-c83976724029">
                        <ee:message>
                            <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	"status":"error",
	"message":"Required quantity for " ++ vars.exceededProduct ++ " is not available"
}]]></ee:set-payload>
                        </ee:message>
                    </ee:transform>
                </on-error-propagate>
                <on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="d0a58ee3-fe68-49f6-9688-d09a65d1535d" type="APP:NOT_DELIVERABLE">
					<set-variable value="#[output application/json&#10;---&#10;422]" doc:name="Set Variable" doc:id="2ba7a35a-db53-49b3-b9e1-86ef4f6d0f71" variableName="httpStatus" />
					<logger level="INFO" doc:name="Logger" doc:id="9c35d5c7-082e-4c91-a6c2-9d6883d4f1d7" message='#[output application/json&#10;---&#10;{&#10;	info:"not deliverable error raised",&#10;	error:"location entered by customer is currently out of our deliverable regiom"&#10;}]' />
					<ee:transform doc:name="Transform Message" doc:id="524d4bd3-cee4-443b-8efb-852bbe6eeb21">
						<ee:message>
							<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	error:"notDeliverable",
	message:"product cannot be delivered at " ++ payload[0].city
}]]></ee:set-payload>
						</ee:message>
					</ee:transform>
