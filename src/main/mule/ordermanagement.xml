		<ee:transform doc:name="Transform Message" doc:id="06294a8a-2487-4357-8b06-b73523ff2740">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json

var groupedOutput = do{
	(payload map (value)->{
	productId:value.product_id,
	productName:value.product_name,
	brand:value.brand,
	quantity:value.quantity,
	status:if(value.quantity>=10) "inStock" else if(value.quantity>0 and value.quantity<10) "lowStock" else "outOfStock"
})
	
}

var finalOutput=do{
	if(vars.status != null) (groupedOutput filter $.status==vars.status) else groupedOutput
}
---

finalOutput groupBy $.status]]></ee:set-payload>
            </ee:message>
        </ee:transform>
    </flow>
    <flow name="get:\order\(custId):ordermanagement-config" doc:id="5a3fff4e-f7fd-427d-bf6f-184aa688bccf">
