    <flow name="get:\product\stockStatus:ordermanagement-config">
        <set-variable value="#[attributes.queryParams.status]" doc:name="status" doc:id="a686f406-4b27-4937-bad3-4e388e039ddf" variableName="status" />
        <db:select doc:name="getAllData" doc:id="d9beb58f-badf-46dd-9667-6de241a69ed5" config-ref="Database_Config">
            <db:sql><![CDATA[select * from inventory;]]></db:sql>
        </db:select>
        <ee:transform doc:name="Transform Message" doc:id="06294a8a-2487-4357-8b06-b73523ff2740">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json

var groupedOutput = do{
	(payload map (value)->{
	productId:value.product_id,
	productName:value.product_name,
	brand:value.brand,
	quantity:value.quantity,
	status:if(value.quantity>=10) "inStock" else if(value.quantity>0 and value.quantity<10) "lowStock" else "outOfStock"
})
	
}

var finalOutput=do{
	if(vars.status != null) (groupedOutput filter $.status==vars.status) else groupedOutput
}
---

finalOutput groupBy $.status]]></ee:set-payload>
            </ee:message>
        </ee:transform>
    </flow>
    <flow name="get:\order\(custId):ordermanagement-config" doc:id="5a3fff4e-f7fd-427d-bf6f-184aa688bccf">
        <set-variable value="#[attributes.queryParams.orderId]" doc:name="orderId" doc:id="fc556223-682a-47c4-8e7e-84cc792083f1" variableName="orderId" />
        <db:select doc:name="ordersList" doc:id="f3f698cd-19b6-4eb3-a7b5-95bf23ce0b5b" config-ref="Database_Config">
            <db:sql><![CDATA[select * from order_table where cust_id=:custId;]]></db:sql>
            <db:input-parameters><![CDATA[#[{
	custId:attributes.uriParams.custId
}]]]></db:input-parameters>
        </db:select>
        <set-variable value="#[payload]" doc:name="ordersList" doc:id="cbef12c9-6ba9-4dc7-acba-56860bc9124c" variableName="ordersList" />
        <set-variable value="#[[]]" doc:name="listOfItems" doc:id="ada71138-fe24-40ec-944c-f16c98cbbd3a" variableName="listOfItems" />
        <foreach doc:name="For Each" doc:id="541f1c01-1a55-418b-93c8-63a45a7e9b88" collection="#[payload]">
            <db:select doc:name="orderItems" doc:id="e455347b-7e4d-4ffe-98c4-c43989344dd6" config-ref="Database_Config">
                <db:sql><![CDATA[select * from order_items where order_id=:orderId;]]></db:sql>
                <db:input-parameters><![CDATA[#[{
	orderId:payload.order_id
}]]]></db:input-parameters>
            </db:select>
            <set-variable value="#[vars.listOfItems + payload]" doc:name="listOfItems" doc:id="b65d132c-07f1-4b00-8c7f-bfef8f8b39d3" variableName="listOfItems" />
        </foreach>
        <ee:transform doc:name="final response" doc:id="927cd82c-f7ec-4938-8cdd-f9843db1d854">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json

var filteredOrders = do{
	if(vars.orderId != null) 
	(vars.ordersList filter $.order_id == vars.orderId) else vars.ordersList
}
---
filteredOrders map (value)->do{
	var items = (flatten(vars.listOfItems) filter $.order_id==value.order_id)
	---
	{
		"status":value.delivery_status,
		"data":{
			order_id:value.order_id,
			customer_id:value.cust_id,
			order_date:value.order_date,
			expected_delivery_date:value.exp_del_date,
			total_amount:value.total_order_price,
			items:items map{
				product_id:$.product_id,
				quantity:$.quantity,
				unitPrice:$.order_price,
				totalPrice:($.order_price)*($.quantity)
			}
		}
	}
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <logger level="INFO" message="get:\order:ordermanagement-config" />
    </flow>
</mule>
